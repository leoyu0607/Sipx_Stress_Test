diff --git a/gui/src-tauri/Cargo.toml b/gui/src-tauri/Cargo.toml
--- a/gui/src-tauri/Cargo.toml	(revision 0e71811f0aa83bd8bfc170cc974fc2433658011a)
+++ b/gui/src-tauri/Cargo.toml	(date 1777624407914)
@@ -4,8 +4,10 @@
 edition = "2021"
 
 [lib]
-name        = "sipress_gui_lib"
-crate-type  = ["cdylib", "rlib"]
+# cdylib → Tauri mobile / dynamic linking
+# rlib   → Desktop binary can link against it
+name       = "sipress_gui_lib"
+crate-type = ["cdylib", "rlib"]
 
 [[bin]]
 name = "sipress-gui"
@@ -13,13 +15,30 @@
 
 [dependencies]
 sipress-core = { path = "../../core" }
-tauri        = { version = "2", features = ["protocol-asset"] }
-tokio        = { workspace = true }
-anyhow       = { workspace = true }
-serde        = { workspace = true }
-serde_json   = { workspace = true }
-tracing      = { workspace = true }
-tracing-subscriber = "0.3"
+
+# Tauri 2.x — protocol-asset 讓前端 asset 能透過 tauri:// 協定載入
+tauri = { version = "2", features = [] }
+
+# 非同步執行時（由 workspace 繼承版本）
+tokio = { workspace = true, features = ["full"] }
+
+# 序列化（Config / StatsSnapshot / FinalReport 的 Serialize/Deserialize）
+serde      = { workspace = true, features = ["derive"] }
+serde_json = { workspace = true }
+
+# 錯誤處理
+anyhow = { workspace = true }
+
+# 日誌
+tracing            = { workspace = true }
+tracing-subscriber = { version = "0.3", features = ["env-filter"] }
+
+# Tauri 官方 plugin（桌面檔案對話框、開啟外部連結）
+tauri-plugin-dialog = "2"
+tauri-plugin-opener = "2"
+
+[build-dependencies]
+tauri-build = { version = "2", features = [] }
 
 [features]
 default         = ["custom-protocol"]
