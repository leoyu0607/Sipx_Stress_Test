-// Learn more about Tauri commands at https://tauri.app/develop/calling-rust/
-#[tauri::command]
-fn greet(name: &str) -> String {
-    format!("Hello, {}! You've been greeted from Rust!", name)
-}
+/// lib.rs — Tauri application entry point
+///
+/// 修正點：
+/// - 移除原本的 greet() stub，正確掛載 AppState 與四個 commands
+/// - 透過 .manage() 注入 Arc<AppState>，讓所有 Command 共享同一狀態
+/// - tracing 初始化改用 try_init()，避免與 main.rs 重複初始化 panic
+
+mod commands;
+
+use std::sync::Arc;
+use tracing_subscriber::EnvFilter;
+
+use commands::AppState;
 
 #[cfg_attr(mobile, tauri::mobile_entry_point)]
 pub fn run() {
+    // 初始化 tracing（try_init 讓 main/lib 兩者都安全呼叫）
+    let _ = tracing_subscriber::fmt()
+        .with_env_filter(
+            EnvFilter::try_from_default_env().unwrap_or_else(|_| "warn".into()),
+        )
+        .try_init();
+
     tauri::Builder::default()
-        .plugin(tauri_plugin_opener::init())
-        .plugin(tauri_plugin_dialog::init())
-        .invoke_handler(tauri::generate_handler![greet])
+        // AppState 透過 Arc 共享，Tauri State<Arc<AppState>> 即可取用
+        .manage(Arc::new(AppState::default()))
+        .invoke_handler(tauri::generate_handler![
+            commands::start_test,
+            commands::stop_test,
+            commands::get_snapshot,
+            commands::get_report,
+        ])
         .run(tauri::generate_context!())
-        .expect("error while running tauri application");
+        .expect("Tauri 啟動失敗");
 }
